{
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"__TRACKER_BIN__\" register",
                        "timeout": 20
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"__TRACKER_BIN__\" prompt",
                        "timeout": 5
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"__TRACKER_BIN__\" update",
                        "timeout": 20
                    }
                ]
            }
        ],
        "SessionEnd": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"__TRACKER_BIN__\" end",
                        "timeout": 20
                    }
                ]
            }
        ]
    }
}
